# Contact form email configuration (Resend)
# 1. Sign up at https://resend.com
# 2. Verify your domain (recommended: florensservices.com)
#    OR use 'onboarding@resend.dev' for testing (only sends to your Resend account email)
# 3. Create an API key and paste it below (replace re_xxxxxxxxx)
# 4. Set CONTACT_EMAIL to the address where you want to receive form submissions

RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
CONTACT_EMAIL=Business@florensservices.com
